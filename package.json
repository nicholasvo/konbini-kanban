{
	"name": "konbini-kanban",
	"version": "0.1.0",
	"description": "A Linear-style kanban board as a custom Bases view.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"bases",
		"kanban"
	],
	"author": "nicholasvo",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^20.11.0",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"esbuild": "0.20.0",
		"obsidian": "latest",
		"tslib": "^2.6.2",
		"typescript": "^5.4.0"
	}
}
